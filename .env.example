# ===================================================
# BookHeaven Environment Variables Template
# ===================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# DO NOT commit the real .env file — it is gitignored.
# ===================================================

# ===== Database =====
MYSQL_ROOT_PASSWORD=your_mysql_root_password
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/reactlibrarydatabase
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_db_password

# ===== JWT =====
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# ===== Internal Service Communication =====
INTERNAL_SERVICE_SECRET=your_internal_service_secret
GATEWAY_COMMUNICATION_SECRET=your_gateway_communication_secret

# ===== Email (Gmail SMTP) =====
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password
STORE_ADMIN_EMAIL=your_admin_email@gmail.com

# ===== Razorpay (Payment Service) =====
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ===== Stripe (Payment Service) =====
STRIPE_API_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ===== Google OAuth2 =====
OAUTH2_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH2_GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH2_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth2/callback

# ===== RabbitMQ =====
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# ===== Redis =====
SPRING_DATA_REDIS_HOST=localhost
SPRING_REDIS_HOST=localhost

# ===== Elasticsearch =====
SPRING_ELASTICSEARCH_URIS=http://localhost:9200

# ===== Eureka =====
EUREKA_URL=http://localhost:8761/eureka

# ===== Frontend =====
FRONTEND_URL=http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_API_GATEWAY_URL=http://localhost:8090
VITE_OAUTH2_REDIRECT_URI=http://localhost:5173/oauth2/callback
